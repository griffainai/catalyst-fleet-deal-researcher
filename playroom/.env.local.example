# Anthropic API key (required for the researcher to actually respond)
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default model.
# The public demo runs on Haiku for cost control. Override to Sonnet for sharper output.
# ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Optional: per-IP rate limit (requests per rolling window). Defaults below.
# RATE_LIMIT_MAX=12
# RATE_LIMIT_WINDOW_MS=60000
